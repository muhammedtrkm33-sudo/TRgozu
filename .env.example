# ===== EMAIL / SMTP AYARLARI =====
# Render ortamunda aşağıdaki SMTP değişkenlerini kullanın.
# Eğer sadece EMAIL_ değişkenlerini kullanmak isterseniz, yine çalışır.

SMTP_USER=your-email@gmail.com
SMTP_PASS=your-smtp-password
SMTP_FROM="TR-GOZU <your-email@gmail.com>"
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false

# Alternatif olarak eski format:
# EMAIL_USER=your-email@gmail.com
# EMAIL_PASS=your-smtp-password
# EMAIL_FROM="TR-GOZU <your-email@gmail.com>"
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_SECURE=false

# ===== SUNUCU AYARLARI =====
PORT=10000